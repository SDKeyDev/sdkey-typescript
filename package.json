{
  "name": "@sdkey/sdk",
  "version": "0.3.0",
  "description": "Official TypeScript client for the SDKey license authentication protocol",
  "license": "MIT",
  "author": "SDKey",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "PROTOCOL.md",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "keywords": [
    "sdkey",
    "license",
    "authentication",
    "ed25519",
    "aes-gcm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SDKeyDev/sdkey-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/SDKeyDev/sdkey-typescript/issues"
  },
  "homepage": "https://docs.sdkey.dev",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
